---
layout: false

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const zhCnPath = `${basePath}/zh-cn/`;
const enPath = `${basePath}/en/`;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mai_xiyu Projects</title>
    <meta name="description" content="Mai_xiyu's Project Hub">
    <script define:vars={{ zhCnPath, enPath }}>
        const userLang = navigator.language || navigator.userLanguage;
        const isZhCN = userLang.toLowerCase().includes('zh');
        const targetPath = isZhCN ? zhCnPath : enPath;

        window.location.replace(targetPath);
    </script>
    <style>
        :root {
            color-scheme: light dark;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: #f8fafc;
            color: #172033;
        }

        main {
            width: min(100%, 32rem);
        }

        .eyebrow {
            margin: 0 0 0.75rem;
            color: #526071;
            font-size: 0.82rem;
            font-weight: 650;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        h1 {
            margin: 0 0 0.75rem;
            font-size: clamp(1.75rem, 5vw, 2.4rem);
            line-height: 1.1;
        }

        p {
            margin: 0 0 1.5rem;
            color: #526071;
            line-height: 1.65;
        }

        .links {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        a {
            border: 1px solid #cbd5e1;
            border-radius: 0.45rem;
            color: #1d4ed8;
            font-weight: 650;
            padding: 0.55rem 0.75rem;
            text-decoration: none;
        }

        a:hover {
            border-color: #1d4ed8;
        }

        .redirect-note {
            color: #526071;
            font-size: 0.88rem;
        }

        @media (prefers-color-scheme: dark) {
            body {
                background: #0f1318;
                color: #eef2f7;
            }

            .eyebrow,
            p,
            .redirect-note {
                color: #a8b3c1;
            }

            a {
                border-color: #374151;
                color: #93c5fd;
            }
        }

        @media (max-width: 480px) {
            body {
                justify-content: flex-start;
            }

            .links {
                flex-direction: column;
            }

            a {
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <main>
        <p class="eyebrow">Mai_xiyu Projects</p>
        <h1>Project documentation</h1>
        <p class="redirect-note">Selecting the matching language page. If the redirect does not start, choose a language below.</p>
        <nav class="links" aria-label="Language selection">
            <a href={zhCnPath}>简体中文</a>
            <a href={enPath}>English</a>
        </nav>
    </main>

    <noscript>
        <style>
            .redirect-note { display: none; }
        </style>
    </noscript>
</body>
</html>
