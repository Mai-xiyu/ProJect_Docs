---
layout: false

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found | Mai_xiyu Projects</title>
    <meta name="description" content="The requested documentation page could not be found.">
    <style>
        :root {
            color-scheme: dark;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            background: #0f172a;
            color: #e2e8f0;
        }

        .skip-link {
            position: absolute;
            left: 16px;
            top: 16px;
            color: inherit;
            padding: 8px 12px;
            border-radius: 8px;
            transform: translateY(-200%);
            transition: transform 0.2s ease;
        }

        .skip-link:focus {
            transform: translateY(0);
            background: #e2e8f0;
            color: #0f172a;
            outline: 2px solid #93c5fd;
            outline-offset: 2px;
        }

        main {
            width: min(100%, 720px);
            padding: 32px;
            border-radius: 16px;
            background: rgba(15, 23, 42, 0.9);
            box-shadow: 0 12px 40px rgba(15, 23, 42, 0.35);
        }

        h1 {
            margin-top: 0;
        }

        a {
            color: #93c5fd;
        }
    </style>
</head>
<body>
    <a class="skip-link" href="#content">Skip to content</a>
    <main id="content">
        <h1>Page Not Found</h1>
        <p>The page you are looking for does not exist, has moved, or the link is incorrect.</p>
        <ul>
            <li><a href={`${basePath}/en/`}>Go back to the documentation home</a></li>
            <li><a href={`${basePath}/en/guide/user-guide/`}>Open the User Guide</a></li>
            <li><a href="https://github.com/Mai-xiyu">Visit Mai_xiyu on GitHub</a></li>
        </ul>
    </main>
</body>
</html>
